# Copia este archivo a .env y rellena los valores. NUNCA subas .env al repo.

# ── Email (Postmark) ──
POSTMARK_API_KEY=
FROM_EMAIL="Arcos Fitness <no-reply@arcosfitness.com>"
OWNER_EMAIL="info@arcosfitness.com"

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Base de datos (Supabase Postgres) ──
# DATABASE_URL: pooler en modo transacción (puerto 6543) para el runtime.
#   schema=app mantiene las tablas FUERA de `public` (PostgREST no las expone).
#   pgbouncer=true desactiva prepared statements (requerido por el pooler).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&schema=app"
# DIRECT_URL: conexión directa (puerto 5432) SOLO para migraciones de Prisma.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=app"

# ── Panel de recepción (/recepcion) ──
ADMIN_EMAIL="recepcion@arcosfitness.com"
ADMIN_INITIAL_PASSWORD="cambia-esto"
# Secreto para firmar la cookie de sesión (HMAC). Genera uno: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ── Cron (barrido de holds / retención) ──
# Genera uno: openssl rand -hex 32
CRON_SECRET=
